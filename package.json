{
  "name": "findmydoc-portal",
  "version": "1.0.0",
  "description": "International patient clinic discovery platform built with PayloadCMS and Next.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "prepare": "node scripts/setup-hooks.mjs",
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev",
    "dev:redirect-blocker": "cross-env DEPLOYMENT_ENV=preview NEXT_PUBLIC_DEPLOYMENT_ENV=preview pnpm dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate": "cross-env NODE_OPTIONS=--no-deprecation node scripts/generate.mjs",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint --ext .ts,.tsx,.js,.jsx ./src ./tests ./scripts --cache --max-warnings=0",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint --ext .ts,.tsx,.js,.jsx ./src ./tests ./scripts --fix --cache --max-warnings=0",
    "typegen": "cross-env NODE_OPTIONS=--no-deprecation next typegen",
    "check": "cross-env NODE_OPTIONS=--no-deprecation pnpm run lint && pnpm run typegen && pnpm run check:payload-types && tsc --noEmit",
    "tests": "cross-env NODE_OPTIONS=--no-deprecation NODE_ENV=test vitest run",
    "tests:show-logs": "cross-env NODE_OPTIONS=--no-deprecation NODE_ENV=test TEST_SHOW_LOGS=1 vitest run",
    "tests:watch": "cross-env NODE_OPTIONS=--no-deprecation vitest",
    "tests:e2e": "cross-env NODE_OPTIONS=--no-deprecation playwright test --config=playwright.config.ts",
    "tests:e2e:smoke": "pnpm tests:e2e:smoke:admin",
    "tests:e2e:smoke:admin": "cross-env NODE_OPTIONS=--no-deprecation playwright test --config=playwright.config.ts --project admin-auth --project admin-smoke --grep @smoke",
    "tests:e2e:regression:admin": "cross-env NODE_OPTIONS=--no-deprecation playwright test --config=playwright.config.ts --project admin-regression-platform --project admin-regression-clinic --grep @regression",
    "tests:e2e:smoke:public": "cross-env NODE_OPTIONS=--no-deprecation playwright test --config=playwright.config.ts --project public-smoke --grep @smoke",
    "tests:e2e:headed": "cross-env NODE_OPTIONS=--no-deprecation playwright test --config=playwright.config.ts --headed",
    "tests:e2e:debug": "cross-env NODE_OPTIONS=--no-deprecation PWDEBUG=1 playwright test --config=playwright.config.ts",
    "matrix:verify": "pnpm dlx tsx scripts/permission-matrix/verify.ts",
    "matrix:derive": "pnpm dlx tsx scripts/permission-matrix/derive-json.ts",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "ci": "cross-env NODE_OPTIONS=--no-deprecation bash -c 'pnpm run migrate && pnpm build'",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "migrate": "pnpm run payload migrate",
    "generateDBFromScratch": "cross-env NODE_OPTIONS=--no-deprecation find src/migrations -type f -delete && pnpm run generate && payload migrate:create --skip-empty && pnpm run payload migrate:fresh",
    "vercel:preview": "vercel build --target=preview",
    "seed:run": "pnpm dlx tsx scripts/seed-run.ts",
    "playwright:session:record": "pnpm dlx tsx scripts/playwright-session-record.ts",
    "playwright:session:check": "pnpm dlx tsx scripts/playwright-session-check.ts",
    "playwright:journey:capture": "pnpm dlx tsx scripts/playwright-journey-capture.ts",
    "admin:journey:coverage": "pnpm dlx tsx scripts/admin-journey-coverage.ts",
    "images:optimize": "pnpm dlx tsx scripts/optimize-images.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:check": "node scripts/docs-consistency-check.mjs",
    "stories:governance:check": "node scripts/storybook/validate-story-governance.mjs",
    "check:payload-types": "bash .github/scripts/ci/check-payload-types.sh",
    "coverage:merge": "node scripts/coverage/merge-coverage.mjs",
    "ai:slop-check": "node scripts/ai-slop-policy-check.mjs",
    "ai:slop-check:prepush": "node scripts/ai-slop-pre-push-check.mjs",
    "hooks:install": "node scripts/setup-hooks.mjs",
    "cleanup": "node scripts/cleanup.mjs",
    "deadcode:check": "cross-env NODE_OPTIONS=\"--no-deprecation -r tsconfig-paths/register\" knip --production --strict --include files,exports",
    "deps:graph:check": "depcruise --config .dependency-cruiser.cjs \"src/**/*.ts\" \"src/**/*.tsx\"",
    "deps:dedupe:check": "pnpm dedupe --check --lockfile-only",
    "deps:audit": "audit-ci --high --package-manager pnpm --report-type summary",
    "deps:outdated": "pnpm outdated --recursive",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.82.1",
    "@payloadcms/live-preview-react": "3.82.1",
    "@payloadcms/next": "3.82.1",
    "@payloadcms/payload-cloud": "3.82.1",
    "@payloadcms/plugin-form-builder": "3.82.1",
    "@payloadcms/plugin-import-export": "3.82.1",
    "@payloadcms/plugin-mcp": "3.82.1",
    "@payloadcms/plugin-nested-docs": "3.82.1",
    "@payloadcms/plugin-redirects": "3.82.1",
    "@payloadcms/plugin-search": "3.82.1",
    "@payloadcms/plugin-seo": "3.82.1",
    "@payloadcms/richtext-lexical": "3.82.1",
    "@payloadcms/storage-s3": "3.82.1",
    "@payloadcms/ui": "3.82.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^10.1.0",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.13.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-sitemap": "^4.2.3",
    "payload": "3.82.1",
    "payload-admin-bar": "^1.0.7",
    "posthog-js": "^1.369.3",
    "posthog-node": "^5.29.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "7.72.1",
    "react-icons": "^5.6.0",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/css": "^1.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@fontsource/dm-sans": "^5.2.8",
    "@next/eslint-plugin-next": "16.2.4",
    "@playwright/test": "1.59.1",
    "@poupe/eslint-plugin-tailwindcss": "^0.3.1",
    "@radix-ui/react-slider": "^1.3.6",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/node": "25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "4.1.5",
    "audit-ci": "^7.1.0",
    "copyfiles": "^2.4.1",
    "dependency-cruiser": "^17.3.10",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.3.5",
    "jsdom": "^29.0.2",
    "knip": "^6.6.3",
    "pg": "^8.19.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "shadcn": "^4.4.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": "^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "@poupe/eslint-plugin-tailwindcss",
      "esbuild",
      "msw",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "@modelcontextprotocol/sdk@<1.26.0": ">=1.26.0",
      "ajv@8.17.1": "8.18.0",
      "drizzle-orm@<0.45.2": "0.45.2",
      "hono@<4.12.12": "4.12.12",
      "file-type@<21.3.3": "21.3.3",
      "fast-xml-parser@<=5.5.6": "5.5.7",
      "happy-dom": "20.8.9",
      "minimatch@<10.2.3": ">=10.2.3",
      "immutable@<4.3.8": ">=4.3.8",
      "nodemailer@<8.0.5": "8.0.5",
      "rollup@<4.59.0": ">=4.59.0",
      "diff@<4.0.4": ">=4.0.4",
      "flatted@<=3.4.1": "3.4.2",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "protobufjs@<7.5.5": "7.5.5"
    }
  },
  "packageManager": "pnpm@10.28.2"
}
