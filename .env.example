# Database connection string
DATABASE_URI=postgresql://postgres:password@postgres:5432/findmydoc-portal

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Feature Flags
FEATURE_DEVELOPER_DASHBOARD=true

# Optional: enable Payload schema push for throwaway local experiments only.
# Default workflow keeps this disabled and relies on explicit migrations.
PAYLOAD_DB_PUSH=false

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Optional deployment environment override (portable; takes precedence over VERCEL_ENV)
# Supported values: development | preview | production
DEPLOYMENT_ENV=development

# Optional public deployment environment override for edge/runtime parity (middleware)
# Supported values: development | preview | production
NEXT_PUBLIC_DEPLOYMENT_ENV=development

# Temporary preview guard toggle (set true to enable preview lock in-app)
PREVIEW_GUARD_ENABLED=false

# Optional global logo overrides for frontend chrome
# Example: /brand-header-logo.png or https://cdn.example.com/brand-header-logo.png
NEXT_PUBLIC_HEADER_LOGO_SRC=
NEXT_PUBLIC_FOOTER_LOGO_SRC=

# Optional logo override for preview lock screens (used only when deployment env is preview)
# Example: /preview-logo.png or https://cdn.example.com/preview-logo.png
NEXT_PUBLIC_PREVIEW_LOGO_SRC=

# Supabase configuration for authentication
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# if true, the app will use s3 in development
USE_S3_IN_DEV=false

# S3-compatible storage configuration (e.g., Supabase S3)
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_ID # S3 storage access key ID
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_ACCESS_KEY # S3 storage secret access key
S3_REGION=YOUR_S3_REGION # S3 storage region
S3_BUCKET=YOUR_S3_BUCKET_NAME # S3 storage bucket name
S3_ENDPOINT=YOUR_S3_ENDPOINT # S3 storage endpoint URL

# PostHog configuration for analytics
NEXT_PUBLIC_POSTHOG_KEY=KEY_XXXXXXXX
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Test & runtime logging options (optional):
# Controls Payload's internal logger level. When unset, tests default to 'error'.
# Values: 'error' | 'warn' | 'info' | 'debug'
# Set PAYLOAD_LOG_LEVEL=debug when you need detailed storage-path diagnostics locally.
# Example:
# PAYLOAD_LOG_LEVEL=debug

# To display test-time console logs (the test runner is quiet by default),
# do NOT commit TEST_SHOW_LOGS to your .env files. Instead, run locally like:
# TEST_SHOW_LOGS=1 pnpm tests --project=integration
# or use the provided convenience script:
# pnpm tests:show-logs
